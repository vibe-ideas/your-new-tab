---
import type { Dict, Lang } from '../i18n';
import { otherLang, localizedPath } from '../i18n';

interface Props {
  t: Dict;
  lang: Lang;
}

const { t, lang } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = localizedPath(base, otherLang(lang));
---

<a class="lang-switch" href={href} aria-label="switch language">
  {t.nav.switchLang}
</a>

<style>
  .lang-switch {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: var(--ink-2);
    font-size: 0.85rem;
    background: #fff;
  }
  .lang-switch:hover {
    color: var(--brand-blue-2);
    border-color: var(--brand-blue-2);
    text-decoration: none;
  }
</style>
