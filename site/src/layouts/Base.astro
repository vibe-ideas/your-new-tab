---
import '../styles/global.css';
import type { Dict, Lang } from '../i18n';

interface Props {
  t: Dict;
  lang: Lang;
}

const { t, lang } = Astro.props;
const base = import.meta.env.BASE_URL;
const iconHref = `${base}icon.svg`;
const canonicalPath = lang === 'zh' ? base : `${base}en/`;
const canonical = new URL(canonicalPath, Astro.site).toString();
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'} dir={t.dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t.htmlTitle}</title>
    <meta name="description" content={t.htmlDesc} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={iconHref} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={t.htmlTitle} />
    <meta property="og:description" content={t.htmlDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(`${base}demo.gif`, Astro.site).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t.htmlTitle} />
    <meta name="twitter:description" content={t.htmlDesc} />
    <meta name="theme-color" content="#2563eb" />
  </head>
  <body>
    <slot />
  </body>
</html>
